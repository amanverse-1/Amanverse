{
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "59 23 * * *"
    },
    {
      "path": "/api/cron/weekly",
      "schedule": "59 23 * * 0"
    }
  ],
  "rewrites": [
    {
      "source": "/api/cron/(.*)",
      "destination": "/api/cron/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/admin(.*)",
      "destination": "/admin.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
